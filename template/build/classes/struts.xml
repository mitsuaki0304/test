<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE struts PUBLIC
"-//Apache Software Foundation//DTD Struts Configuration 2.3//EN"
"http://struts.apache.org/dtds/struts-2.3.dtd">

<struts>
<constant name="struts.devMode" value="true"/>
<package name="com.internousdev.template.action" extends="struts-default">
<!-- HomeAction -->
<action name="Homeaction" class="com.internousdev.template.action.HomeAction" method="execute">
<result name="succss">login.jsp</result>
</action>

<!-- LoginAction -->
<action name="LoginAction" class="com.internousdev.template.action.LoginAction" method="execute">
<result name="success">buyItem.jsp</result>
<result name="error">home.jsp</result>
</action>

<!-- UserCreateAction -->
<action name="LoginAction" class="com.internousdev.template.action.UserCreateAction" method="execute">
<result name="success">userCreate.jsp</result>
</action>

<!-- UserCreateConfirmAction -->
<action name="UserCreateConfirmAction"
class="com.internouddev.template.action.UserCreateConfirmAction" method="execute">
<result name="success">userCreateConfirm.jsp</result>
<result name="error">userCreat.jsp</result>
</action>

<!-- UserCreateCompleteAction -->
<action name="UserCreateCompleteAction"
class="com.internouddev.tempate.action.UserCreateAction" method="execute">
<result name="success">userCreateComplete.jsp</result>
</action>

<!-- BuyItemAction -->
<action name="BuyItemAction"
class="com.internouddev.tempate.action.BuyItemAction" method="execute">
<result name="success">buyItemCofirm.jsp</result>
</action>

<!-- BuyItemConfirmAction -->
<action name="BuyItemConfirmAction"
class="com.internouddev.tempate.action.BuyItemConfirmAction" method="execute">
<result name="success">buyItemComplete.jsp</result>
</action>

<!-- MyPageAction -->
<action name="MyPageAction"
class="com.internouddev.tempate.action.MyPageAction" method="execute">
<result name="success">myPage.jsp</result>
</action>

</package>
</struts>