<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.3//EN"
"http://struts.apache.org/dtds/struts-2.3.dtd">
<struts>
	<constant name="struts.devMode" value="true" />
	<package name="com.sample.spsite.action"
		extends="struts-default">

		<action name="BuyItemListAction"
			class="com.sample.spsite.action.BuyItemListAction" method="execute">
			<result name="success">buyItemList.jsp</result>
		</action>

		<action name="AdminAction"
			class="com.sample.spsite.action.AdminAction" method="execute">
			<result name="success">admin.jsp</result>
		</action>

		<action name="ItemCreateAction"
			class="com.sample.spsite.action.ItemCreateAction" method="execute">
			<result name="success">itemCreate.jsp</result>
		</action>

		<action name="ItemCreateConfirmAction"
			class="com.sample.spsite.action.ItemCreateConfirmAction" method="execute">
			<result name="success">itemCreateConfirm.jsp</result>
			<result name="error">itemCreate.jsp</result>
		</action>

		<action name="ItemCreateCompleteAction"
			class="com.sample.spsite.action.ItemCreateCompleteAction" method="execute">
			<result name="success">itemCreateComplete.jsp</result>
		</action>

		<action name="BuyItemDetailAction"
			class="com.sample.spsite.action.BuyItemDetailAction" method="execute">
			<result name="success">buyItemDetail.jsp</result>
		</action>

		<action name="SortAction"
			class="com.sample.spsite.action.SortAction" method="execute">
			<result name="success">buyItemList.jsp</result>
		</action>





	</package>
</struts>