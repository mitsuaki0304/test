
package com.sample.spsite.action;

import java.util.Map;

import org.apache.struts2.interceptor.SessionAware;

import com.opensymphony.xwork2.ActionSupport;
import com.sample.spsite.dao.LoginDAO;
import com.sample.spsite.dto.LoginDTO;

public class LoginAction extends ActionSupport implements SessionAware {
	private String loginUserId;
	private String loginPassword;

	public Map<String, Object> session;
	private LoginDAO loginDAO = new LoginDAO();
	private LoginDTO loginDTO = new LoginDTO();
	private String type;
	public String execute() {

		System.out.println("loginActionのtype判定"+type);
		String result = ERROR;
		loginDTO = loginDAO.getLoginUserInfo(loginUserId, loginPassword);
		session.put("loginUser", loginDTO);

		if (((LoginDTO) session.get("loginUser")).getLoginFlg()) {

			result = SUCCESS;

			session.put("login_user_id", loginDTO.getLoginId());
			session.put("user_name", loginDTO.getUserName());

			if (loginDTO.getAdminFlg()) {

				result = "admin";
				return result;
			}
//			else if(type.equals("cartpage")){
//				result="cart";
//				return result;
//			}

			switch(type){
			case "cartpage":
				result="cart";
				return result;

			case "mypage":
				result="mypage";
				return result;
			}
		}
		return result;
	}

	public String getLoginUserId() {
		return loginUserId;
	}

	public void setLoginUserId(String loginUserId) {
		this.loginUserId = loginUserId;
	}

	public String getLoginPassword() {
		return loginPassword;
	}

	public void setLoginPassword(String loginPassword) {
		this.loginPassword = loginPassword;
	}

	public String getType() {
		return type;
	}

	public void setType(String type) {
		this.type = type;
	}

	@Override
	public void setSession(Map<String, Object> session) {
		this.session = session;
	}

}
